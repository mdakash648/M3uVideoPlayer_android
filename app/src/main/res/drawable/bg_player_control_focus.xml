<?xml version="1.0" encoding="utf-8"?>
<!--
  promt1 — TV D-pad focus highlight. Used as an ImageButton *foreground* so the existing touch
  ripple background is preserved while a clear, "clean" focus ring appears on the currently
  focused control (Play/Pause by default). Transparent when not focused/pressed.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFFFFF" />
            <corners android:radius="8dp" />
            <stroke
                android:width="2dp"
                android:color="@color/televizo_accent" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#22FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <color android:color="@android:color/transparent" />
    </item>
</selector>
