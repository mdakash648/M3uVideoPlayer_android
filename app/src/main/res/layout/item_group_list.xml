<?xml version="1.0" encoding="utf-8"?>
<!-- Folder row used by GroupAdapter's LIST mode and reused for folder hits in search results. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:focusable="true"
    android:background="@drawable/sel_item_focus"
    android:stateListAnimator="@animator/focus_scale"
    android:minHeight="56dp"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <ImageView
        android:id="@+id/imageFolderIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_folder"
        android:contentDescription="@null"
        app:tint="@color/televizo_accent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textGroupName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/televizo_text_primary"
        android:textSize="15sp"
        app:layout_constraintTop_toTopOf="@id/imageFolderIcon"
        app:layout_constraintBottom_toTopOf="@id/textGroupCount"
        app:layout_constraintStart_toEndOf="@id/imageFolderIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintHorizontal_bias="0"
        tools:text="Bangla Entertainment" />

    <TextView
        android:id="@+id/textGroupCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/televizo_text_secondary"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/textGroupName"
        app:layout_constraintBottom_toBottomOf="@id/imageFolderIcon"
        app:layout_constraintStart_toEndOf="@id/imageFolderIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        tools:text="24 channels" />

</androidx.constraintlayout.widget.ConstraintLayout>
