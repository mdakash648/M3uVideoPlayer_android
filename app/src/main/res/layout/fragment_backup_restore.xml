<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup & Restore screen — two action rows ("Save Application Data" / "Load Application Data")
  styled like the Settings menu rows. The back button + title live on the shared MaterialToolbar,
  configured by BackupRestoreFragment. progressOverlay blocks input while an export/import runs.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/televizo_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/backup_restore_subtitle"
                android:textColor="@color/televizo_text_secondary"
                android:textSize="13sp" />

            <!-- ===================== SAVE APPLICATION DATA (Export) ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSaveData"
                style="@style/Settings.MenuCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_backup"
                        app:tint="@color/televizo_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/action_save_application_data"
                            android:textColor="@color/televizo_text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/action_save_application_data_subtitle"
                            android:textColor="@color/televizo_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_media_next" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== LOAD APPLICATION DATA (Import) ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLoadData"
                style="@style/Settings.MenuCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_restore"
                        app:tint="@color/televizo_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/action_load_application_data"
                            android:textColor="@color/televizo_text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/action_load_application_data_subtitle"
                            android:textColor="@color/televizo_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_media_next" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== LOAD DEMO DATA (bundled sample) ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLoadDemoData"
                style="@style/Settings.MenuCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_link"
                        app:tint="@color/televizo_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/action_load_demo_data"
                            android:textColor="@color/televizo_text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/action_load_demo_data_subtitle"
                            android:textColor="@color/televizo_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_media_next" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Blocks input and shows a spinner while an export/import is running. -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99121216"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/televizo_accent" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
