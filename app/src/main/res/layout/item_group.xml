<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:focusable="true"
    android:clickable="true"
    android:longClickable="true"
    android:foreground="@drawable/sel_item_focus"
    android:stateListAnimator="@animator/focus_scale"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/televizo_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingVertical="16dp"
        android:paddingHorizontal="8dp">

        <ImageView
            android:id="@+id/imageFolderIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_folder"
            app:tint="@color/televizo_accent"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/textGroupName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="@color/televizo_text_primary"
            android:textSize="13sp"
            tools:text="Bangla Entertainment" />

        <TextView
            android:id="@+id/textGroupCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/televizo_text_secondary"
            android:textSize="11sp"
            tools:text="24 channels" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
