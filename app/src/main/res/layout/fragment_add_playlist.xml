<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/televizo_bg"
    android:fillViewport="true"
    tools:context=".ui.addplaylist.AddPlaylistFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/add_playlist_subtitle"
            android:textColor="@color/televizo_text_secondary"
            android:textSize="14sp" />

        <!-- ===================== SOURCE ===================== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/AddPlaylist.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/AddPlaylist.SectionHeader"
                    android:text="@string/section_source" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:theme="@style/ThemeOverlay.AddPlaylist.Accent"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonTypeM3u"
                        style="@style/AddPlaylist.Button.Toggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/type_m3u" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonTypeXtream"
                        style="@style/AddPlaylist.Button.Toggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/type_xtream" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutUrl"
                    style="@style/AddPlaylist.Field"
                    android:hint="@string/playlist_url"
                    app:startIconDrawable="@drawable/ic_link"
                    app:startIconTint="@color/televizo_accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:textColor="@color/televizo_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/textOr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="@string/paste_url_or_attach"
                    android:textColor="@color/televizo_text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAttachFile"
                    style="@style/AddPlaylist.Button.Attach"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/attach_file"
                    app:icon="@drawable/ic_attach_file"
                    app:iconGravity="textStart" />

                <!-- Selected-file chip row; shown once a file is attached. -->
                <LinearLayout
                    android:id="@+id/layoutSelectedFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_selected_file"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_attach_file" />

                    <TextView
                        android:id="@+id/textFileName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="middle"
                        android:paddingVertical="10dp"
                        android:singleLine="true"
                        android:textColor="@color/televizo_text_primary"
                        android:textSize="14sp"
                        tools:text="my_playlist.m3u" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonRemoveFile"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:contentDescription="@string/remove_file"
                        android:text="✕"
                        android:textColor="@color/televizo_text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== DETAILS ===================== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/AddPlaylist.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/AddPlaylist.SectionHeader"
                    android:text="@string/section_details" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutName"
                    style="@style/AddPlaylist.Field"
                    android:hint="@string/playlist_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/televizo_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutUsername"
                    style="@style/AddPlaylist.Field"
                    android:hint="@string/xtream_username"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/televizo_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutPassword"
                    style="@style/AddPlaylist.Field"
                    android:hint="@string/xtream_password"
                    android:visibility="gone"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/televizo_accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/televizo_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== AUTO-UPDATE ===================== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/AddPlaylist.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/AddPlaylist.SectionHeader"
                    android:text="@string/how_often_to_update" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutFrequency"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/how_often_to_update_hint"
                    app:boxStrokeColor="@color/sl_edittext_stroke"
                    app:hintTextColor="@color/televizo_accent"
                    android:textColorHint="@color/televizo_text_secondary">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdownFrequency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="16dp"
                        android:textColor="@color/televizo_text_primary"
                        android:background="@null" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== ACTIONS ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Edit-mode only; stays gone on the Add Playlist screen. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRemovePlaylist"
                style="@style/AddPlaylist.Button.Danger"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remove_playlist"
                android:visibility="gone"
                tools:visibility="visible" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cancel"
                android:textColor="@color/televizo_text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="28dp"
                android:text="@string/save"
                android:textColor="@color/black"
                app:backgroundTint="@color/sl_button_accent" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:indeterminateTint="@color/televizo_accent"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
