<?xml version="1.0" encoding="utf-8"?>
<!--
  Settings screen — top-level menu. Each row opens its own dedicated screen; the back arrow +
  "Settings" title live on the shared MaterialToolbar, configured by SettingsFragment.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/televizo_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- ===================== PLAYLISTS ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMenuPlaylists"
            style="@style/Settings.MenuCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@null"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/televizo_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_menu_playlists"
                        android:textColor="@color/televizo_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_menu_playlists_subtitle"
                        android:textColor="@color/televizo_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:alpha="0.5"
                    android:contentDescription="@null"
                    android:src="@android:drawable/ic_media_next" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== BACKUP & RESTORE ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMenuBackupRestore"
            style="@style/Settings.MenuCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@null"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="@color/televizo_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_menu_backup_restore"
                        android:textColor="@color/televizo_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_menu_backup_restore_subtitle"
                        android:textColor="@color/televizo_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:alpha="0.5"
                    android:contentDescription="@null"
                    android:src="@android:drawable/ic_media_next" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== DISPLAY (custom column counts) ===================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_section_display"
            android:textAllCaps="true"
            android:textColor="@color/televizo_accent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Grid View Columns stepper -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Settings.MenuCard"
            android:clickable="false"
            android:focusable="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_view_mode"
                    app:tint="@color/televizo_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_grid_columns"
                        android:textColor="@color/televizo_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_grid_columns_subtitle"
                        android:textColor="@color/televizo_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnGridColumnsMinus"
                    style="@style/Settings.Stepper.Button"
                    android:contentDescription="@string/column_count_decrease"
                    android:src="@drawable/ic_remove" />

                <TextView
                    android:id="@+id/textGridColumnsValue"
                    style="@style/Settings.Stepper.Value"
                    tools:text="Auto" />

                <ImageButton
                    android:id="@+id/btnGridColumnsPlus"
                    style="@style/Settings.Stepper.Button"
                    android:contentDescription="@string/column_count_increase"
                    android:src="@drawable/ic_add" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Poster View Columns stepper -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Settings.MenuCard"
            android:clickable="false"
            android:focusable="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_view_mode"
                    app:tint="@color/televizo_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_poster_columns"
                        android:textColor="@color/televizo_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_poster_columns_subtitle"
                        android:textColor="@color/televizo_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnPosterColumnsMinus"
                    style="@style/Settings.Stepper.Button"
                    android:contentDescription="@string/column_count_decrease"
                    android:src="@drawable/ic_remove" />

                <TextView
                    android:id="@+id/textPosterColumnsValue"
                    style="@style/Settings.Stepper.Value"
                    tools:text="Auto" />

                <ImageButton
                    android:id="@+id/btnPosterColumnsPlus"
                    style="@style/Settings.Stepper.Button"
                    android:contentDescription="@string/column_count_increase"
                    android:src="@drawable/ic_add" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
