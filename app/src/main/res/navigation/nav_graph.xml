<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/playlistFragment">

    <fragment
        android:id="@+id/playlistFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.playlist.PlaylistFragment"
        android:label="Playlists"
        tools:layout="@layout/fragment_playlist">

        <action
            android:id="@+id/action_playlistFragment_to_addPlaylistFragment"
            app:destination="@id/addPlaylistFragment" />

        <action
            android:id="@+id/action_playlistFragment_to_groupListFragment"
            app:destination="@id/groupListFragment" />

        <action
            android:id="@+id/action_playlistFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/addPlaylistFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.addplaylist.AddPlaylistFragment"
        android:label="Add Playlist"
        tools:layout="@layout/fragment_add_playlist">
        <action
            android:id="@+id/action_addPlaylistFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/groupListFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.group.GroupListFragment"
        android:label="Groups"
        tools:layout="@layout/fragment_group_list">

        <argument
            android:name="playlistId"
            app:argType="long" />

        <!--
            All Series sub-screen: when true, this folder screen lists only per-series subfolders
            (SERIES channels grouped by group-title), with no pinned All/Favorite tiles and sort
            disabled. Set by the "All Series" tile via the self-action below.
        -->
        <argument
            android:name="seriesOnly"
            app:argType="boolean"
            android:defaultValue="false" />

        <action
            android:id="@+id/action_groupListFragment_to_channelListFragment"
            app:destination="@id/channelListFragment" />

        <action
            android:id="@+id/action_groupListFragment_self"
            app:destination="@id/groupListFragment" />

        <action
            android:id="@+id/action_groupListFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settingsFragment_to_settingsPlaylistsFragment"
            app:destination="@id/settingsPlaylistsFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_backupRestoreFragment"
            app:destination="@id/backupRestoreFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsPlaylistsFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.settings.SettingsPlaylistsFragment"
        android:label="Playlists"
        tools:layout="@layout/fragment_settings_playlists">

        <action
            android:id="@+id/action_settingsPlaylistsFragment_to_editPlaylistFragment"
            app:destination="@id/editPlaylistFragment" />
    </fragment>

    <fragment
        android:id="@+id/editPlaylistFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.editplaylist.EditPlaylistFragment"
        android:label="Edit Playlist"
        tools:layout="@layout/fragment_add_playlist">

        <argument
            android:name="playlistId"
            app:argType="long" />

        <action
            android:id="@+id/action_editPlaylistFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/backupRestoreFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.settings.BackupRestoreFragment"
        android:label="Backup &amp; Restore"
        tools:layout="@layout/fragment_backup_restore" />

    <fragment
        android:id="@+id/channelListFragment"
        android:name="com.mdaksh.m3uvideoplayer.ui.channel.ChannelListFragment"
        android:label="Channels"
        tools:layout="@layout/fragment_channel_list">

        <argument
            android:name="playlistId"
            app:argType="long" />

        <!--
            Optional group-title filter, set by GroupListFragment. Null/blank means "no filter".
            Consumed by ChannelListViewModel (Step 4.2) to filter the channel list to this group.
        -->
        <argument
            android:name="groupName"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />

        <!--
            Set by GroupListFragment's pinned "Favorite" tile. When true, groupName is ignored and
            the channel list shows only isFavorite channels for this playlist.
        -->
        <argument
            android:name="favoritesOnly"
            app:argType="boolean"
            android:defaultValue="false" />

        <!--
            Optional contentType filter (MOVIE / SERIES), set by the "All Movies" tile and the
            per-series subfolders. Null/blank means "no contentType filter". Consumed by
            ChannelListViewModel alongside groupName.
        -->
        <argument
            android:name="contentFilter"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />

        <action
            android:id="@+id/action_channelListFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

</navigation>
