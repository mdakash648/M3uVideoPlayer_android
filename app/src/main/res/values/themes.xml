<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.M3uVideoPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/televizo_bg</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/televizo_accent</item>
        <item name="colorSecondaryVariant">@color/televizo_accent</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/televizo_bg</item>
        <item name="colorSurface">@color/televizo_surface</item>
        <item name="android:colorBackground">@color/televizo_bg</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/televizo_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Popup Menu Styles -->
        <item name="popupMenuStyle">@style/Widget.M3uVideoPlayer.PopupMenu</item>
        <item name="actionBarPopupTheme">@style/Theme.M3uVideoPlayer.Popup</item>

        <!-- Dialog Styles -->
        <item name="materialAlertDialogTheme">@style/Theme.M3uVideoPlayer.Dialog</item>
    </style>

    <style name="Widget.M3uVideoPlayer.PopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@color/tv_popup_bg</item>
    </style>

    <style name="Theme.M3uVideoPlayer.Popup" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:popupBackground">@color/tv_popup_bg</item>
        <item name="android:textColorPrimary">@color/tv_popup_text</item>
        <item name="android:textColor">@color/tv_popup_text</item>
        <item name="colorOnSurface">@color/tv_popup_text</item>
        <!-- For checkable items if any -->
        <item name="colorSecondary">@color/televizo_accent</item>
        <item name="controlBackground">@color/televizo_accent</item>
    </style>

    <style name="Theme.M3uVideoPlayer.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowBackground">@color/tv_popup_bg</item>
        <item name="colorSurface">@color/tv_popup_bg</item>
        <item name="android:textColorPrimary">@color/tv_popup_text</item>
        <item name="android:textColorSecondary">@color/televizo_text_secondary</item>
        <item name="colorOnSurface">@color/tv_popup_text</item>
        <!-- Radio buttons and checkboxes color -->
        <item name="colorSecondary">@color/televizo_accent</item>
        <item name="colorControlActivated">@color/televizo_accent</item>
    </style>

    <style name="ThemeOverlay.AddPlaylist.Accent" parent="">
        <item name="colorPrimary">@color/televizo_accent</item>
        <item name="colorOnPrimary">@color/black</item>
    </style>

    <!-- Step 9 — fullscreen, black-background theme for the LibVLC player screen. -->
    <style name="Theme.M3uVideoPlayer.Player" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="colorSecondary">@color/televizo_accent</item>
        <item name="materialAlertDialogTheme">@style/Theme.M3uVideoPlayer.Dialog</item>
    </style>
</resources>
