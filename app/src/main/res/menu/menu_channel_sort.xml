<?xml version="1.0" encoding="utf-8"?>
<!-- PopupMenu shown when the Folder Content screen's sort toolbar action is tapped: how the
     channels inside the current folder are ordered. Independent of menu_folder_sort (which orders
     the folder tiles themselves) — same options, separate persisted setting. -->
<menu xmlns:android="http://schemas.android.com/apk/res/android">
    <group android:checkableBehavior="single">
        <item
            android:id="@+id/sort_ascending"
            android:title="@string/sort_ascending" />
        <item
            android:id="@+id/sort_descending"
            android:title="@string/sort_descending" />
        <item
            android:id="@+id/sort_playlist"
            android:title="@string/sort_playlist" />
    </group>
</menu>
